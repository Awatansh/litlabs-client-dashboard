# =====================
# DATABASE
# =====================
DATABASE_URL=sqlite+aiosqlite:///./dashboard.db

# =====================
# AUTHENTICATION
# =====================
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# =====================
# FILE STORAGE (MinIO)
# =====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=litlabs-deliverables
MINIO_SECURE=false
PRESIGNED_URL_EXPIRY=3600

# =====================
# META ADS (Facebook/Instagram)
# Leave empty = mock mode
# Get from: Business Manager → System Users → Generate Token
# =====================
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=

# =====================
# GOOGLE (shared service account for GSC + GA4)
# Leave empty = mock mode
# Get: Cloud Console → Create Service Account → Download JSON key
# The JSON content as a single-line escaped string
# =====================
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SEARCH_CONSOLE_SITE_URL=
GA4_PROPERTY_ID=

# =====================
# GOOGLE ADS
# Leave empty = mock mode
# Requires separate developer token application
# =====================
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# =====================
# LINKEDIN ADS
# Leave empty = mock mode
# Token expires in 60 days — implement refresh flow for production
# =====================
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=

# =====================
# HUBSPOT CRM
# Leave empty = mock mode
# Get: HubSpot → Settings → Integrations → Private Apps → Create
# =====================
HUBSPOT_ACCESS_TOKEN=

# =====================
# AUTOMATION WEBHOOKS
# Per-client secret key for webhook verification
# =====================
WEBHOOK_SECRET_KEY=dev-webhook-key-change-in-production

# =====================
# SCHEDULER INTERVALS
# =====================
META_FETCH_INTERVAL_HOURS=6
GA4_FETCH_INTERVAL_HOURS=6
SEO_FETCH_INTERVAL_HOURS=24

# =====================
# FRONTEND
# =====================
NEXT_PUBLIC_API_URL=http://localhost:8000
